rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // 管理者判定: admins コレクションに自分のメールのドキュメントが存在するか（旧アプリと同じ）
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    function isProtectedType(data) {
      return data.extendedProps.type in ['fixed', 'no-sound', 'club-event'];
    }

    match /events/{eventId} {
      allow read: if true;
      // 予約はログイン不要（匿名）。固定枠・音出し禁止は管理者のみ作成可。
      allow create: if isProtectedType(request.resource.data) ? isAdmin() : true;
      // 削除・変更も同様。通常枠はクライアント側の本人確認(記入者名)で運用する（旧アプリと同じ方式）。
      allow update, delete: if isProtectedType(resource.data) ? isAdmin() : true;
    }

    match /admins/{adminId} {
      allow read: if true;
      // 既存の管理者のみが管理者を追加・削除できる（初回はConsoleから手動追加）
      allow write: if isAdmin();
    }

    // 操作ログ: 全部員が閲覧可能（仕様）。作成は自由、改ざん防止のため更新・削除は不可。
    match /logs/{logId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    match /dailyMemos/{memoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/notice {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 講義棟空き状況（GitHub Actions が Admin SDK で書き込む。クライアントは読み取りのみ）
    match /settings/lectureHall {
      allow read: if true;
      allow write: if false;
    }

    // 部員プロファイル（新アプリ用）: 本人のみ作成・更新できる
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    // バンド（バンド掲示板）: ログイン不要（予約と同じ匿名運用）。
    // 作成は自由。更新は「名前・ジャンルの編集」か「解散」（status: disbanded への変更）のみ。
    // 代表者名(representative)と作成日時は変更不可。
    match /bands/{bandId} {
      allow read: if true;
      allow create: if true;
      allow update: if
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'genre'])) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
         request.resource.data.status == 'disbanded');
    }

    // 狙い表明（15分グリッド）: 予約と同じくログイン不要・誰でも宣言・削除できる。
    match /slotIntents/{intentId} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;
    }

    // 部誌（つぶやき）: ログイン不要。削除はクライアント側の名前一致確認で運用（events と同方針）。
    match /posts/{postId} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;
    }
  }
}